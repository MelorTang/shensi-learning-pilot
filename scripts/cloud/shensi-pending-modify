#!/usr/bin/env bash
set -euo pipefail

CHAT_ID="${1:-}"
shift || true
TEXT="${*:-${SHENSI_MODIFY_TEXT:-}}"

MODIFY_URL="${SHENSI_PENDING_MODIFY_URL:-http://127.0.0.1:8000/hermes/pending/latest/modify}"
CARD_URL="${SHENSI_CARD_SEND_URL:-http://127.0.0.1:8000/hermes/pending/latest/card/send}"
LOG_DIR="${SHENSI_LOG_DIR:-/home/admin/.hermes/logs}"
LOG="$LOG_DIR/shensi-pending-modify.log"
mkdir -p "$LOG_DIR"

log() {
  echo "$(date -Is) $*" >> "$LOG"
}

if [[ -z "$CHAT_ID" ]]; then
  echo "没有找到当前飞书会话，请稍后再试。"
  log "missing_chat_id"
  exit 0
fi

if [[ -z "$TEXT" ]]; then
  echo "请直接说要修改的题号和内容，比如：第3题其实是对的。"
  log "missing_text chat=$CHAT_ID"
  exit 0
fi

python3 - "$CHAT_ID" "$TEXT" "$MODIFY_URL" "$CARD_URL" <<'PY' >> "$LOG" 2>&1
import json
import sys
import urllib.error
import urllib.request

chat_id, text, modify_url, card_url = sys.argv[1:5]


def post_json(url: str, payload: dict) -> dict:
    req = urllib.request.Request(
        url,
        data=json.dumps(payload, ensure_ascii=False).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.loads(resp.read().decode("utf-8"))


try:
    modify_result = post_json(
        modify_url,
        {
            "confirmed_by": "feishu_parent",
            "text": text,
        },
    )
    print(json.dumps({"stage": "modify", "result": modify_result}, ensure_ascii=False))
    if not modify_result.get("modified"):
        print(json.dumps({"stage": "modify_no_change", "text": text}, ensure_ascii=False))
    send_result = post_json(
        card_url,
        {
            "receive_id": chat_id,
            "receive_id_type": "chat_id",
        },
    )
    print(json.dumps({"stage": "card_send", "result": send_result}, ensure_ascii=False))
except urllib.error.HTTPError as exc:
    body = exc.read().decode("utf-8", errors="replace")
    print(
        json.dumps(
            {
                "ok": False,
                "http_status": exc.code,
                "reason": exc.reason,
                "response_body": body,
                "text": text,
            },
            ensure_ascii=False,
        )
    )
    raise
PY

echo "已按你的说明更新分析，并发送了新的确认卡。"
