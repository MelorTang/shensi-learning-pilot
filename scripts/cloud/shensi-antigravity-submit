#!/usr/bin/env bash
set -euo pipefail

IMAGE_PATH="${1:-}"
MESSAGE_ID="${2:-ag-$(date +%s)}"
SUBJECT="${3:-math}"
GRADE="${4:-grade8}"
NOTE="${5:-Antigravity vision analysis}"

VISION="${SHENSI_ANTIGRAVITY_VISION:-/home/admin/bin/shensi-antigravity-vision}"
SHENSI_URL="${SHENSI_URL:-http://127.0.0.1:8000/ingest/mistake-analysis}"
LOG_DIR="${SHENSI_LOG_DIR:-/home/admin/.hermes/logs}"
LOG="$LOG_DIR/shensi-antigravity-submit.log"
PARENT_LOG="${SHENSI_PARENT_LOG:-}"
mkdir -p "$LOG_DIR"

now_ms() {
  date +%s%3N
}

log() {
  local line
  line="$(date -Is) $*"
  echo "$line" >> "$LOG"
  if [[ -n "$PARENT_LOG" ]]; then
    echo "$line" >> "$PARENT_LOG"
  fi
}

json_error() {
  python3 - "$@" <<'PY'
import json
import sys

stage, code, message, message_id, image_path = sys.argv[1:6]
print(json.dumps({
    "ok": False,
    "stage": stage,
    "error": code,
    "message": message,
    "message_id": message_id,
    "image_path": image_path,
}, ensure_ascii=False))
PY
}

SCRIPT_START_MS="$(now_ms)"
log "phase=submit_wrapper_start image=$IMAGE_PATH message_id=$MESSAGE_ID subject=$SUBJECT grade=$GRADE"

if [[ -z "$IMAGE_PATH" ]]; then
  json_error "input" "missing_image_path" "image_path argument is required" "$MESSAGE_ID" ""
  exit 2
fi

if [[ ! -f "$IMAGE_PATH" ]]; then
  json_error "input" "image_not_found" "image file does not exist" "$MESSAGE_ID" "$IMAGE_PATH"
  exit 3
fi

if [[ ! -x "$VISION" ]]; then
  json_error "vision" "vision_not_found" "vision wrapper is not executable" "$MESSAGE_ID" "$IMAGE_PATH"
  exit 4
fi

SAFE_ID="$(printf '%s' "$MESSAGE_ID" | tr -c 'A-Za-z0-9_.-' '_')"
VISION_OUT="$LOG_DIR/${SAFE_ID}.vision.out"
VISION_ERR="$LOG_DIR/${SAFE_ID}.vision.err"
PAYLOAD_JSON="$LOG_DIR/${SAFE_ID}.payload.json"
RESPONSE_JSON="$LOG_DIR/${SAFE_ID}.shensi-response.json"

VISION_START_MS="$(now_ms)"
log "phase=vision_start message_id=$MESSAGE_ID image=$IMAGE_PATH"
set +e
"$VISION" "$IMAGE_PATH" "$SUBJECT" "$GRADE" >"$VISION_OUT" 2>"$VISION_ERR"
vision_status=$?
set -e

if [[ "$vision_status" -ne 0 ]]; then
  stderr_preview="$(head -40 "$VISION_ERR" | tr '\n' ' ' | cut -c1-800)"
  stdout_preview="$(head -40 "$VISION_OUT" | tr '\n' ' ' | cut -c1-800)"
  log "vision_failed status=$vision_status stdout=$stdout_preview stderr=$stderr_preview"
  json_error "vision" "vision_failed" "vision exited with status $vision_status" "$MESSAGE_ID" "$IMAGE_PATH"
  exit "$vision_status"
fi
log "phase=vision_done message_id=$MESSAGE_ID elapsed_ms=$(( $(now_ms) - VISION_START_MS )) output=$VISION_OUT error=$VISION_ERR"

VALIDATE_START_MS="$(now_ms)"
if ! python3 -m json.tool "$VISION_OUT" >/dev/null 2>>"$LOG"; then
  stdout_preview="$(head -80 "$VISION_OUT" | tr '\n' ' ' | cut -c1-1200)"
  stderr_preview="$(head -80 "$VISION_ERR" | tr '\n' ' ' | cut -c1-1200)"
  log "vision_invalid_json stdout=$stdout_preview stderr=$stderr_preview"
  json_error "vision" "invalid_json" "vision stdout was not valid JSON; see $VISION_OUT and $VISION_ERR" "$MESSAGE_ID" "$IMAGE_PATH"
  exit 10
fi
log "phase=vision_json_validated message_id=$MESSAGE_ID elapsed_ms=$(( $(now_ms) - VALIDATE_START_MS ))"

PAYLOAD_START_MS="$(now_ms)"
python3 - "$VISION_OUT" "$PAYLOAD_JSON" "$MESSAGE_ID" "$IMAGE_PATH" "$SUBJECT" "$GRADE" "$NOTE" <<'PY'
import json
import os
import sys

analysis_path, payload_path, message_id, image_path, subject, grade, note = sys.argv[1:]

with open(analysis_path, "r", encoding="utf-8") as f:
    analysis = json.load(f)

if analysis.get("ok") is False:
    raise SystemExit(f"vision returned error: {analysis}")

analysis.setdefault("provider", "antigravity")
analysis.setdefault("model", "gemini-via-antigravity")
analysis.setdefault("subject", subject)
analysis.setdefault("grade", grade)

payload = {
    "message_id": message_id,
    "platform": "feishu",
    "sender_id": os.environ.get("SHENSI_SENDER_ID", "hermes-antigravity"),
    "chat_id": os.environ.get("SHENSI_CHAT_ID", "hermes-antigravity"),
    "image_path": image_path,
    "subject": subject,
    "grade": grade,
    "note": note,
    "auto_confirm": False,
    "analysis": analysis,
}

with open(payload_path, "w", encoding="utf-8") as f:
    json.dump(payload, f, ensure_ascii=False)
PY
log "phase=payload_build_done message_id=$MESSAGE_ID elapsed_ms=$(( $(now_ms) - PAYLOAD_START_MS )) payload=$PAYLOAD_JSON"

INGEST_START_MS="$(now_ms)"
log "phase=ingest_start message_id=$MESSAGE_ID url=$SHENSI_URL"
set +e
curl -sS -X POST "$SHENSI_URL" \
  -H "Content-Type: application/json" \
  --data-binary @"$PAYLOAD_JSON" \
  >"$RESPONSE_JSON" 2>>"$LOG"
curl_status=$?
set -e

if [[ "$curl_status" -ne 0 ]]; then
  log "shensi_post_failed status=$curl_status response_file=$RESPONSE_JSON"
  json_error "submit" "shensi_post_failed" "curl exited with status $curl_status" "$MESSAGE_ID" "$IMAGE_PATH"
  exit "$curl_status"
fi
log "phase=ingest_http_done message_id=$MESSAGE_ID elapsed_ms=$(( $(now_ms) - INGEST_START_MS )) response=$RESPONSE_JSON"

RESPONSE_VALIDATE_START_MS="$(now_ms)"
if ! python3 -m json.tool "$RESPONSE_JSON" >/dev/null 2>>"$LOG"; then
  response_preview="$(head -80 "$RESPONSE_JSON" | tr '\n' ' ' | cut -c1-1200)"
  log "shensi_invalid_json response=$response_preview"
  json_error "submit" "shensi_invalid_json" "Shensi response was not valid JSON; see $RESPONSE_JSON" "$MESSAGE_ID" "$IMAGE_PATH"
  exit 11
fi
log "phase=ingest_json_validated message_id=$MESSAGE_ID elapsed_ms=$(( $(now_ms) - RESPONSE_VALIDATE_START_MS ))"

log "phase=submit_wrapper_done message_id=$MESSAGE_ID total_elapsed_ms=$(( $(now_ms) - SCRIPT_START_MS )) response_file=$RESPONSE_JSON"
cat "$RESPONSE_JSON"
