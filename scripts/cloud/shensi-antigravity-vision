#!/usr/bin/env bash
set -euo pipefail

AGY="${AGY_BIN:-/home/admin/.local/bin/agy}"
IMAGE_PATH="${1:-}"
SUBJECT="${2:-math}"
GRADE="${3:-grade8}"
TIMEOUT_SECONDS="${AGY_TIMEOUT_SECONDS:-150}"

json_error() {
  python3 - "$@" <<'PY'
import json
import sys

code, message, image_path = sys.argv[1:4]
payload = {
    "ok": False,
    "error": code,
    "message": message,
}
if image_path:
    payload["image_path"] = image_path
print(json.dumps(payload, ensure_ascii=False))
PY
}

if [[ -z "$IMAGE_PATH" ]]; then
  json_error "missing_image_path" "image_path argument is required" ""
  exit 2
fi

if [[ ! -f "$IMAGE_PATH" ]]; then
  json_error "image_not_found" "image file does not exist" "$IMAGE_PATH"
  exit 3
fi

if [[ ! -x "$AGY" ]]; then
  json_error "agy_not_found" "Antigravity CLI is not executable" "$IMAGE_PATH"
  exit 4
fi

OUT="$(mktemp /tmp/shensi-agy-vision.XXXXXX.out)"
ERR="$(mktemp /tmp/shensi-agy-vision.XXXXXX.err)"
trap 'rm -f "$OUT" "$ERR"' EXIT

PROMPT=$(cat <<PROMPT_EOF
You are the vision extraction module for Shensi Learning Pilot.

You MUST inspect the actual image file below. Do not infer from filename,
conversation history, or memory. If the image cannot be read, return exactly:
{"ok":false,"error":"cannot_read_image"}

Return one JSON object only. Do not return Markdown fences, explanation,
terminal logs, or natural-language commentary.

Image path:
$IMAGE_PATH

Task:
1. Count every visible numbered question first.
2. Set expected_question_count to that visible count.
3. Extract every visible question into question_items. If one question is partly
   unreadable, still include a placeholder item with visible text and empty
   unknown fields. Never silently omit a visible question.
4. Extract student steps and student answers.
5. Separate the printed question, the student's handwriting, and teacher/red
   marks. Do not treat printed worked examples or red corrections as the
   student's answer.
6. Provide a correctness judgment only when the student's answer and enough
   checking evidence are visible. If geometry proof, diagram reasoning, or
   handwriting is unclear, set is_correct to null and explain uncertainty in
   error_reason instead of guessing.
7. For every question, write a short evidence-based error_reason. If the answer
   appears correct, leave error_reason empty or explain the visible check.
8. Be conservative: do not mark all questions wrong just because the page has
   teacher marks. Prefer needs_parent_review-style uncertainty in the wording
   when evidence is incomplete.
9. For multi-part questions, fill sub_items with concise per-part judgments.
   Keep each sub-item error_reason under 35 Chinese characters when possible.
10. If a teacher mark appears inconsistent with the math, state the math evidence
    and set is_correct based on the evidence, not on the teacher mark alone.

Required JSON shape:
{
  "provider": "antigravity",
  "model": "gemini-via-antigravity",
  "subject": "$SUBJECT",
  "grade": "$GRADE",
  "title": "...",
  "expected_question_count": 0,
  "question_items": [
    {
      "id": 1,
      "question": "...",
      "type": "...",
      "student_steps": ["..."],
      "student_answer": "...",
      "correct_answer": "...",
      "is_correct": null,
      "error_reason": "",
      "concept": "...",
      "error_type": "",
      "sub_items": [
        {
          "label": "(1)",
          "is_correct": null,
          "error_reason": "...",
          "concept": "..."
        }
      ]
    }
  ],
  "student_answer": "...",
  "correct_answer": "...",
  "concepts": ["..."],
  "error_types": ["..."],
  "root_cause": "...",
  "severity": 3,
  "confidence": 0.8,
  "parent_guidance": "..."
}
PROMPT_EOF
)

set +e
timeout "${TIMEOUT_SECONDS}s" "$AGY" \
  --sandbox \
  --dangerously-skip-permissions \
  --add-dir "$(dirname "$IMAGE_PATH")" \
  --print "$PROMPT" \
  --print-timeout "${TIMEOUT_SECONDS}s" \
  >"$OUT" 2>"$ERR"
status=$?
set -e

if [[ "$status" -ne 0 ]]; then
  message="$(head -20 "$ERR" | tr '\n' ' ' | cut -c1-500)"
  json_error "agy_failed" "agy exited with status $status: $message" "$IMAGE_PATH"
  exit "$status"
fi

python3 - "$OUT" "$IMAGE_PATH" <<'PY'
import json
import sys

out_path, image_path = sys.argv[1:3]
text = open(out_path, "r", encoding="utf-8", errors="replace").read().strip()

def fail(code: str, message: str) -> None:
    print(json.dumps({
        "ok": False,
        "error": code,
        "message": message,
        "image_path": image_path,
    }, ensure_ascii=False))
    raise SystemExit(10)

if not text:
    fail("empty_output", "Antigravity returned empty stdout")

def extract_json_object(raw: str) -> str:
    start = raw.find("{")
    if start < 0:
        fail("json_not_found", raw[:500])
    depth = 0
    in_string = False
    escape = False
    for index in range(start, len(raw)):
        char = raw[index]
        if in_string:
            if escape:
                escape = False
            elif char == "\\":
                escape = True
            elif char == '"':
                in_string = False
            continue
        if char == '"':
            in_string = True
        elif char == "{":
            depth += 1
        elif char == "}":
            depth -= 1
            if depth == 0:
                return raw[start:index + 1]
    fail("json_incomplete", raw[:500])

candidate = extract_json_object(text)
try:
    data = json.loads(candidate)
except json.JSONDecodeError as exc:
    fail("invalid_json", f"{exc}: {candidate[:500]}")

if not isinstance(data, dict):
    fail("json_not_object", "Top-level JSON value is not an object")

data.setdefault("provider", "antigravity")
data.setdefault("model", "gemini-via-antigravity")
print(json.dumps(data, ensure_ascii=False))
PY
